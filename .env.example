# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API). Do NOT commit .env.local.
#
# SUPABASE_SERVICE_ROLE_KEY is a SECRET that bypasses Row Level Security.
# It is used on the server only — never expose it to the browser and never
# add a NEXT_PUBLIC_ prefix.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY
