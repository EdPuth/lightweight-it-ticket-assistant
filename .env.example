# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API). Do NOT commit .env.local.
#
# SUPABASE_SERVICE_ROLE_KEY is a SECRET that bypasses Row Level Security.
# It is used on the server only — never expose it to the browser and never
# add a NEXT_PUBLIC_ prefix.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# Anon (public) key — used by the Supabase Auth client for sign in / sign out and
# session cookies (RBAC Auth v1). Safe to expose; found in Supabase dashboard ->
# Project Settings -> API. Required for login to work.
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---------------------------------------------------------------------------
# AI suggestions (server-only). Powers the staff-only "AI suggested reply"
# feature — drafts replies and suggests category/priority via Claude (AI SDK).
#
# ANTHROPIC_API_KEY is OPTIONAL: without it the feature falls back to the local
# template draft and repeats the ticket's current category/priority. Set it to
# enable real AI. Read on the server only — never add a NEXT_PUBLIC_ prefix.
# AI_MODEL optionally overrides the default model (claude-opus-4-8).
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_MODEL=
