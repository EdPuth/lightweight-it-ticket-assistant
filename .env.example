# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API). Do NOT commit .env.local.
#
# SUPABASE_SERVICE_ROLE_KEY is a SECRET that bypasses Row Level Security.
# It is used on the server only — never expose it to the browser and never
# add a NEXT_PUBLIC_ prefix.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# ---------------------------------------------------------------------------
# Login gate (single shared account). All three are read on the server only.
#
# AUTH_EMAIL / AUTH_PASSWORD are OPTIONAL in local dev (they default to
# itsupport@outlook.com / 123456). Override them for any shared/deployed env.
#
# AUTH_SESSION_TOKEN is OPTIONAL in dev but REQUIRED in production: the app
# refuses to start in production without it, because the dev fallback token is
# public in the source and would be trivially forgeable. Use a long random
# string (e.g. `openssl rand -hex 32`).
# ---------------------------------------------------------------------------
AUTH_EMAIL=itsupport@outlook.com
AUTH_PASSWORD=123456
AUTH_SESSION_TOKEN=GENERATE-A-LONG-RANDOM-STRING
